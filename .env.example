# YouTube Kanal ID (örn: UCxxxxxxxxxxxxxxxxxxxxxx)
YOUTUBE_CHANNEL_ID=

# Facebook User Access Token (Graph API Explorer'dan alınır)
FB_USER_ACCESS_TOKEN=

# Kaç dakikada bir kontrol edilsin (varsayılan: 30)
CHECK_INTERVAL_MINUTES=30

# Facebook Sayfaları — Format: PAGE_ID:ACCESS_TOKEN,PAGE_ID:ACCESS_TOKEN
FB_PAGES=

# Video paylaşım modu: "instant" veya "scheduled"
FB_POST_MODE=instant
FB_SCHEDULE_DELAY_MINUTES=60

# Paylaşımda kullanılacak açıklama şablonu
# {title} = video başlığı, {url} = YouTube linki
FB_DESCRIPTION_TEMPLATE={title}

# İndirilen videolar için geçici klasör
DOWNLOAD_DIR=./downloads

# Log seviyesi: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Web UI giriş bilgileri
UI_USERNAME=admin
UI_PASSWORD=admin
FLASK_SECRET=

# Facebook oturum cookie'leri (opsiyonel)
FB_COOKIE_C_USER=
FB_COOKIE_XS=

# Proxy (opsiyonel — residential proxy önerilir)
PROXY_URL=

# Gece modu — bu saatler arasında tüm işlemler duraklar (HH:MM)
# Boş bırakılırsa gece modu devre dışı
QUIET_HOURS_START=
QUIET_HOURS_END=
